# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookshelf

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_PRIVATE_KEY=       # RS256 private key (PEM format, single line with \n escapes)
JWT_PUBLIC_KEY=        # RS256 public key (PEM format, single line with \n escapes)
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
ALLOWED_EMAILS=you@example.com

# External APIs
OPENAI_API_KEY=
GOOGLE_BOOKS_API_KEY=
OPEN_LIBRARY_BASE_URL=https://openlibrary.org

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081
RATE_LIMIT_SCAN=10/minute
